# .env.example

# 1. 数据库配置
MONGO_INITDB_ROOT_USERNAME=admin_user
MONGO_INITDB_ROOT_PASSWORD=admin_secure_password
MONGO_DB_NAME=survey_db

# MongoDB 连接字符串 (供 Python 后端 FastAPI 使用)
MONGODB_URL=mongodb://admin_user:admin_secure_password@localhost:27017/survey_db?authSource=admin

# 2. 身份认证模块配置 (JWT 密钥)
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440